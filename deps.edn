;; clj-fff — Clojure binding to fff via JDK Foreign Function & Memory API.
;;
;; The native lib is resolved at runtime from FFF_NATIVE_PATH, a bundled
;; classpath resource (com.blockether/fff-native-<platform>), or — as a fallback
;; — the matching native jar resolved through Clojure's own dependency machinery
;; (clojure.tools.deps), which honours configured Maven repos/mirrors/settings.xml.
{:paths ["src" "resources"]

 ;; tools.deps powers the runtime native-jar fallback in
 ;; com.blockether.fff/resolve-native-jar — the same resolver the clojure CLI
 ;; uses, so :mvn/repos, mirrors and settings.xml are honoured instead of a
 ;; hand-rolled HTTP GET. Loaded lazily via requiring-resolve, so it is NOT
 ;; pulled into a native image (where the native lib is bundled/explicit).
 :deps {org.clojure/tools.deps {:mvn/version "0.31.1629"}}

 :aliases
 {:build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.6"}
          slipset/deps-deploy {:mvn/version "0.2.2"}}
   :ns-default build}
  :test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   :main-opts ["-m" "cognitect.test-runner"]
   :exec-fn cognitect.test-runner.api/test
   :jvm-opts ["--enable-native-access=ALL-UNNAMED"]}}}
